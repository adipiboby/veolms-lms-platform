    "serviceRawFile": "service: veolms-api\r\n\r\nuseDotenv: true\r\n\r\nprovider:\r\n  name: aws\r\n  runtime: nodejs20.x\r\n  region: ap-south-1\r\n  stage: ${opt:stage, 'dev'}\r\n  memorySize: 1024\r\n  timeout: 30\r\n\r\n  environment:\r\n    NODE_ENV: production\r\n\r\n    MONGO_URI: ${env:MONGO_URI}\r\n    JWT_SECRET: ${env:JWT_SECRET}\r\n    JWT_EXPIRES_IN: ${env:JWT_EXPIRES_IN, '7d'}\r\n\r\n    CLIENT_URL: ${env:CLIENT_URL}\r\n    FRONTEND_URL: ${env:FRONTEND_URL, ''}\r\n    CORS_ORIGINS: ${env:CORS_ORIGINS, ''}\r\n\r\n    GOOGLE_CLIENT_ID: ${env:GOOGLE_CLIENT_ID}\r\n\r\n    RAZORPAY_KEY_ID: ${env:RAZORPAY_KEY_ID, ''}\r\n    RAZORPAY_KEY_SECRET: ${env:RAZORPAY_KEY_SECRET, ''}\r\n\r\n    AWS_S3_REGION: ${env:AWS_S3_REGION, 'us-east-1'}\r\n    AWS_S3_BUCKET_NAME: ${env:AWS_S3_BUCKET_NAME}\r\n\r\n    AWS_CLOUDFRONT_URL: ${env:AWS_CLOUDFRONT_URL}\r\n    CLOUDFRONT_PUBLIC_KEY_ID: ${env:CLOUDFRONT_PUBLIC_KEY_ID}\r\n    CLOUDFRONT_PRIVATE_KEY: ${env:CLOUDFRONT_PRIVATE_KEY, ''}\r\n   \r\n    CLOUDFRONT_PRIVATE_KEY_BASE64: ${env:CLOUDFRONT_PRIVATE_KEY_BASE64, ''}\r\n    CLOUDFRONT_VIDEO_SIGNED_URL_EXPIRES_IN: ${env:CLOUDFRONT_VIDEO_SIGNED_URL_EXPIRES_IN, '3600'}\r\n\r\n    S3_SIGNED_URL_EXPIRES_IN: ${env:S3_SIGNED_URL_EXPIRES_IN, '600'}\r\n\r\n  iam:\r\n    role:\r\n      statements:\r\n        - Effect: Allow\r\n          Action:\r\n            - s3:GetObject\r\n            - s3:PutObject\r\n            - s3:DeleteObject\r\n            - s3:ListBucket\r\n            - s3:AbortMultipartUpload\r\n            - s3:CreateMultipartUpload\r\n            - s3:CompleteMultipartUpload\r\n            - s3:UploadPart\r\n          Resource:\r\n            - arn:aws:s3:::${env:AWS_S3_BUCKET_NAME}\r\n            - arn:aws:s3:::${env:AWS_S3_BUCKET_NAME}/*\r\n\r\n        - Effect: Allow\r\n          Action:\r\n            - mediaconvert:CreateJob\r\n            - mediaconvert:GetJob\r\n            - mediaconvert:DescribeEndpoints\r\n          Resource: \"*\"\r\n\r\nfunctions:\r\n  api:\r\n    handler: src/lambda.handler\r\n    events:\r\n      - httpApi:\r\n          path: /\r\n          method: ANY\r\n      - httpApi:\r\n          path: /{proxy+}\r\n          method: ANY\r\n\r\npackage:\r\n  patterns:\r\n    - \"src/**\"\r\n    - \"node_modules/**\"\r\n    - \"package.json\"\r\n    - \"package-lock.json\"\r\n    - \"!node_modules/.cache/**\"\r\n    - \"!keys/**\"\r\n    - \"!uploads/**\"\r\n    - \"!*.log\"\r\n",
